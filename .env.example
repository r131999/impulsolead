# =============================================
# ImpulsoLead — variáveis de ambiente
# Copie para .env e preencha os valores reais
# =============================================

# --- PostgreSQL ---
POSTGRES_PASSWORD=senha_segura_aqui

# --- JWT ---
JWT_SECRET=string_aleatoria_longa_e_segura

# --- URLs ---
# URL pública do frontend (usada no CORS do servidor)
CLIENT_URL=https://crm.impulsoslz.com.br

# --- Notificação via Evolution API (WhatsApp direto para o corretor) ---
EVOLUTION_API_URL=https://api.impulsoslz.com.br
EVOLUTION_API_KEY=impulso2026_api_key
EVOLUTION_INSTANCE_NAME=nome_da_instancia

# Webhook genérico de fallback (N8N ou outro) — usado apenas se Evolution não estiver configurada
NOTIFICACAO_WEBHOOK_URL=

# --- Chat IA (OpenAI) ---
OPENAI_API_KEY=sk-...
