DATABASE_URL="postgres://usuario:senha@host:5432/banco?sslmode=disable"
JWT_SECRET="seu_jwt_secret_aqui"
JWT_EXPIRES_IN="7d"
PORT=3002
NODE_ENV=development

# Notificação via Evolution API (WhatsApp direto)
EVOLUTION_API_URL=https://api.impulsoslz.com.br
EVOLUTION_API_KEY=impulso2026_api_key
EVOLUTION_INSTANCE_NAME=nome_da_instancia

# Notificação via webhook genérico (N8N ou outro — fallback se Evolution não estiver configurada)
NOTIFICACAO_WEBHOOK_URL=

# --- Chat IA (OpenAI) ---
OPENAI_API_KEY=sk-...

# --- WhatsApp multi-tenant (Baileys Manager) ---
# URL interna do container do manager (padrão para Docker)
BAILEYS_URL=http://impulsolead-whatsapp:3010
# Chave secreta compartilhada entre o servidor e o manager
INTERNAL_KEY=chave_interna_segura_aqui
MANAGER_KEY=chave_manager_segura_aqui

# --- Meta Lead Ads ---
META_WEBHOOK_TOKEN=impulso_meta_webhook_2026
