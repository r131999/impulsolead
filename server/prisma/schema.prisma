generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Imobiliaria {
  id                    String    @id @default(uuid())
  nome                  String
  email                 String    @unique
  telefone              String?
  logoUrl               String?
  plano                 String    @default("trial")
  trialExpiraEm         DateTime?
  planoExpiraEm         DateTime?
  planoBloqueadoEm      DateTime?
  notificacaoVencimento Boolean   @default(false)
  permissoes            Json      @default("{}")
  limiteAcessos         Int       @default(5)
  apiKey                String    @unique
  criadoEm              DateTime  @default(now())
  atualizadoEm          DateTime  @updatedAt

  usuarios               Usuario[]
  corretores             Corretor[]
  leads                  Lead[]
  configAgente           ConfigAgente?
  equipes                Equipe[]
  contatosImportados     ContatoImportado[]
  modelosMensagem        ModeloMensagem[]
  contatosPessoais       ContatoPessoal[]
  imoveis                Imovel[]
  sessoesAgente          SessaoAgente[]
  historicosDistribuicao HistoricoDistribuicao[]
  arquivosImovel         ArquivoImovel[]
  mensagensLead          MensagemLead[]
  whatsappInstancia      WhatsappInstancia?
  metaIntegracao         MetaIntegracao?
  tours                  TourVirtual[]
  apresentacoes          Apresentacao[]
  adSpends               AdSpend[]
  adStatuses             AdStatus[]
}

model Usuario {
  id           String   @id @default(uuid())
  nome         String
  email        String   @unique
  senhaHash    String
  role         String   @default("gestor")
  ativo        Boolean  @default(true)
  telefone     String?
  fotoPerfil   String?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  imobiliariaId String
  imobiliaria   Imobiliaria @relation(fields: [imobiliariaId], references: [id])
}

model Corretor {
  id             String   @id @default(uuid())
  nome           String
  email          String?  @unique
  telefone       String
  whatsapp       String
  ativo          Boolean  @default(true)
  disponivel     Boolean  @default(true)
  posicaoFila    Int      @default(0)
  leadsRecebidos Int      @default(0)
  senhaHash      String?
  usuarioAtivo   Boolean  @default(false)
  role           String   @default("corretor") // "corretor" ou "gerente"
  fotoPerfil     String?
  equipeId       String?
  criadoEm       DateTime @default(now())
  atualizadoEm   DateTime @updatedAt

  imobiliariaId  String
  imobiliaria    Imobiliaria @relation(fields: [imobiliariaId], references: [id])
  equipe         Equipe?     @relation("EquipeCorretores", fields: [equipeId], references: [id])
  equipeLiderada Equipe[]    @relation("EquipeLider")

  leads             Lead[]
  followUps         FollowUp[]
  contatosPessoais  ContatoPessoal[]
  pushSubscriptions PushSubscription[]
}

model Lead {
  id          String @id @default(uuid())
  nome        String
  telefone    String
  whatsappJid String

  primeiroImovel String?
  tipoRenda      String?
  rendaMensal    String?
  restricaoCpf   String?
  valorEntrada   String?
  urgencia       String?
  regiao         String?
  faixaValor     String?

  origem       String?
  campanha     String?
  conjuntoName String?
  anuncioName  String?
  adId         String?
  adsetId      String?
  campaignId   String?
  valorVenda   Decimal? @db.Decimal(12, 2)
  interesse    String?
  nomeEditado  String?

  status            String  @default("lead")
  motivoPerda       String?
  observacoes       String?
  historicoConversa String?
  temConversa       Boolean @default(false)

  corretorId String?
  corretor   Corretor? @relation(fields: [corretorId], references: [id])

  imobiliariaId String
  imobiliaria   Imobiliaria @relation(fields: [imobiliariaId], references: [id])

  historico HistoricoLead[]
  followUps FollowUp[]
  mensagens MensagemLead[]

  ultimaNotificacaoGestor DateTime?
  etapaEntradaEm          DateTime?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

model HistoricoLead {
  id       String   @id @default(uuid())
  acao     String
  detalhes String?
  criadoEm DateTime @default(now())

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id])
}

model Equipe {
  id        String  @id @default(uuid())
  nome      String
  descricao String?
  ativo     Boolean @default(true)

  liderId String?
  lider   Corretor? @relation("EquipeLider", fields: [liderId], references: [id])

  imobiliariaId String
  imobiliaria   Imobiliaria @relation(fields: [imobiliariaId], references: [id])

  corretores Corretor[] @relation("EquipeCorretores")

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

model ContatoImportado {
  id              String   @id @default(uuid())
  nome            String
  telefone        String
  status          String   @default("pendente") // pendente | enviado | convertido | erro
  mensagemEnviada String?
  leadId          String?
  criadoEm        DateTime @default(now())
  atualizadoEm    DateTime @updatedAt

  imobiliariaId String
  imobiliaria   Imobiliaria @relation(fields: [imobiliariaId], references: [id])

  @@unique([telefone, imobiliariaId])
}

model ModeloMensagem {
  id           String   @id @default(uuid())
  nome         String
  conteudo     String
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  imobiliariaId String
  imobiliaria   Imobiliaria @relation(fields: [imobiliariaId], references: [id])
}

model FollowUp {
  id           String   @id @default(uuid())
  dataHora     DateTime
  observacao   String?
  status       String   @default("pendente")
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id])

  corretorId String
  corretor   Corretor @relation(fields: [corretorId], references: [id])
}

model ContatoPessoal {
  id          String  @id @default(uuid())
  nome        String
  telefone    String
  email       String?
  observacoes String?
  status      String  @default("ativo") // "ativo" | "convertido"
  leadId      String?

  corretorId String
  corretor   Corretor @relation(fields: [corretorId], references: [id])

  imobiliariaId String
  imobiliaria   Imobiliaria @relation(fields: [imobiliariaId], references: [id])

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

model Imovel {
  id           String   @id @default(uuid())
  nome         String
  descricao    String
  tipo         String
  localizacao  String
  valorMin     Float?
  valorMax     Float?
  quartos      Int?
  area         String?
  status       String   @default("disponivel")
  destaque     Boolean  @default(false)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  imobiliariaId String
  imobiliaria   Imobiliaria @relation(fields: [imobiliariaId], references: [id])
}

model UsuarioSupremo {
  id           String   @id @default(uuid())
  nome         String
  email        String   @unique
  senhaHash    String
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

model SessaoAgente {
  id            String      @id @default(uuid())
  telefone      String
  nome          String?
  etapaAtual    Int         @default(0)
  respostas     Json        @default("{}")
  status        String      @default("em_andamento") // "em_andamento" | "finalizado"
  instancia     String
  imobiliariaId String
  imobiliaria   Imobiliaria @relation(fields: [imobiliariaId], references: [id])
  criadoEm      DateTime    @default(now())
  atualizadoEm  DateTime    @updatedAt

  @@unique([telefone, imobiliariaId])
}

model ChatConversa {
  id                String   @id @default(uuid())
  participante1Id   String
  participante1Tipo String
  participante2Id   String
  participante2Tipo String
  imobiliariaId     String
  criadoEm          DateTime @default(now())
  atualizadoEm      DateTime @updatedAt

  mensagens ChatMensagem[]

  @@unique([participante1Id, participante2Id])
}

model ChatMensagem {
  id            String       @id @default(uuid())
  conversaId    String
  conversa      ChatConversa @relation(fields: [conversaId], references: [id])
  remetenteId   String
  remetenteTipo String
  remetenteNome String
  conteudo      String
  leadId        String?
  leadNome      String?
  lida          Boolean      @default(false)
  criadoEm      DateTime     @default(now())
}

model HistoricoDistribuicao {
  id                 String   @id @default(uuid())
  leadId             String
  leadNome           String
  leadTelefone       String
  corretorId         String
  corretorNome       String
  distribuidoPor     String // "automatico" ou "manual"
  distribuidoPorNome String?
  criadoEm           DateTime @default(now())

  imobiliariaId String
  imobiliaria   Imobiliaria @relation(fields: [imobiliariaId], references: [id])
}

model ArquivoImovel {
  id           String   @id @default(uuid())
  nome         String
  tipo         String // "foto", "video", "pdf"
  filename     String
  mimetype     String
  tamanho      Int
  criadoPorId  String
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  imobiliariaId String
  imobiliaria   Imobiliaria @relation(fields: [imobiliariaId], references: [id])

  mensagens MensagemLead[]
}

model MensagemLead {
  id            String   @id @default(uuid())
  remetenteTipo String // "lead", "corretor", "sistema"
  remetenteNome String
  remetenteId   String?
  conteudo      String?
  tipoMidia     String? // "texto", "audio", "video", "pdf", "imagem"
  urlMidia      String?
  whatsappMsgId String?
  lida          Boolean  @default(false)
  criadoEm      DateTime @default(now())

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id])

  arquivoImovelId String?
  arquivoImovel   ArquivoImovel? @relation(fields: [arquivoImovelId], references: [id])

  imobiliariaId String
  imobiliaria   Imobiliaria @relation(fields: [imobiliariaId], references: [id])
}

model PushSubscription {
  id           String   @id @default(uuid())
  corretorId   String
  corretor     Corretor @relation(fields: [corretorId], references: [id], onDelete: Cascade)
  subscription String
  criadoEm     DateTime @default(now())
}

model WhatsappInstancia {
  id            String      @id @default(uuid())
  imobiliariaId String      @unique
  imobiliaria   Imobiliaria @relation(fields: [imobiliariaId], references: [id])
  numero        String?
  status        String      @default("desconectado") // desconectado | conectando | aguardando_qr | conectado
  ativo         Boolean     @default(true)
  criadoEm      DateTime    @default(now())
  atualizadoEm  DateTime    @updatedAt
}

model MetaIntegracao {
  id               String      @id @default(uuid())
  imobiliariaId    String      @unique
  imobiliaria      Imobiliaria @relation(fields: [imobiliariaId], references: [id])
  pageId           String
  pageToken        String
  pageName         String?
  adAccountId      String?
  adsToken         String?
  paginasPendentes Json?
  ativo            Boolean     @default(true)
  criadoEm         DateTime    @default(now())
  atualizadoEm     DateTime    @updatedAt
}

model TourVirtual {
  id               String      @id @default(uuid())
  imobiliariaId    String
  imobiliaria      Imobiliaria @relation(fields: [imobiliariaId], references: [id])
  nome             String
  descricao        String?
  slug             String      @unique
  publicado        Boolean     @default(false)
  whatsappCorretor String?
  nomeCorretor     String?
  comodos          Comodo[]
  criadoEm         DateTime    @default(now())
  atualizadoEm     DateTime    @updatedAt
}

model Comodo {
  id       String       @id @default(uuid())
  tourId   String
  tour     TourVirtual  @relation(fields: [tourId], references: [id], onDelete: Cascade)
  nome     String
  ordem    Int
  fotos    FotoComodo[]
  criadoEm DateTime     @default(now())
}

model FotoComodo {
  id       String   @id @default(uuid())
  comodoId String
  comodo   Comodo   @relation(fields: [comodoId], references: [id], onDelete: Cascade)
  url      String
  tamanho  Int
  ordem    Int
  criadoEm DateTime @default(now())
}

model Apresentacao {
  id                    String             @id @default(uuid())
  imobiliariaId         String
  imobiliaria           Imobiliaria        @relation(fields: [imobiliariaId], references: [id])
  corretorId            String?
  nomeImóvel           String
  nomeLocal             String?
  descricao             String?
  valor                 String?
  quartos               Int?
  banheiros             Int?
  vagas                 Int?
  areaM2                Float?
  slug                  String             @unique
  publicado             Boolean            @default(false)
  nomeLeadPersonalizado String?
  whatsappCorretor      String?
  nomeCorretor          String?
  videoUrl              String?
  fotos                 FotoApresentacao[]
  criadoEm              DateTime           @default(now())
  atualizadoEm          DateTime           @updatedAt
}

model FotoApresentacao {
  id             String       @id @default(uuid())
  apresentacaoId String
  apresentacao   Apresentacao @relation(fields: [apresentacaoId], references: [id], onDelete: Cascade)
  url            String
  tamanho        Int
  ambiente       String
  ordem          Int
  criadoEm       DateTime     @default(now())
}

model AdSpend {
  id            String      @id @default(uuid())
  imobiliariaId String
  imobiliaria   Imobiliaria @relation(fields: [imobiliariaId], references: [id])
  adId          String
  adName        String?
  date          DateTime    @db.Date
  spend         Decimal     @db.Decimal(12, 2)
  currency      String      @default("BRL")
  accountId     String
  criadoEm      DateTime    @default(now())
  atualizadoEm  DateTime    @updatedAt

  @@unique([imobiliariaId, adId, date])
  @@index([imobiliariaId, date])
}

model AdStatus {
  id              String      @id @default(uuid())
  imobiliariaId   String
  imobiliaria     Imobiliaria @relation(fields: [imobiliariaId], references: [id])
  adId            String
  effectiveStatus String?
  atualizadoEm    DateTime    @updatedAt

  @@unique([imobiliariaId, adId])
}

model ConfigAgente {
  id                 String   @id @default(uuid())
  mensagemBoasVindas String   @default("Olá! Tudo bem? Aqui é a Lia, assistente virtual. Que bom que você entrou em contato! Como posso te chamar?")
  perguntas          Json
  nomeAgente         String   @default("Lia")
  tomAgente          String   @default("profissional mas leve")
  ativo              Boolean  @default(true)
  distribuicaoManual Boolean  @default(false)
  criadoEm           DateTime @default(now())
  atualizadoEm       DateTime @updatedAt

  imobiliariaId String      @unique
  imobiliaria   Imobiliaria @relation(fields: [imobiliariaId], references: [id])
}
